// EngineerDNA — Prisma schema (Module 2: Authentication & User Management).
// PostgreSQL is the canonical relational store. Neo4j (added later) is a
// projection. Only auth/user tables exist at this stage — feature tables are
// added by their owning modules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum AuthProvider {
  GITHUB
  GOOGLE
}

/// Verification lifecycle for a skill. Self-added skills start CLAIMED; later
/// modules move them to VERIFIED (with evidence) or REFUTED.
enum SkillStatus {
  CLAIMED
  VERIFYING
  VERIFIED
  REFUTED
}

/// Lifecycle of a repository analysis job (Module 5).
enum AnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/// A platform user. Created automatically on first OAuth login.
model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  name         String?
  profileImage String?
  role         Role         @default(STUDENT)
  provider     AuthProvider
  providerId   String
  // Email verification is structure-only for now (OAuth emails are trusted).
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lastLogin    DateTime?

  refreshTokens RefreshToken[]
  profile       Profile?
  githubAccount GithubAccount?

  // A provider account maps to exactly one user.
  @@unique([provider, providerId])
  @@index([email])
}

/// A connected GitHub account (separate from login). Holds the OAuth access
/// token (stored ENCRYPTED at rest) used to import repositories.
model GithubAccount {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @unique @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubUserId String
  githubLogin  String
  accessToken  String // encrypted (AES-256-GCM)
  scope        String?
  connectedAt  DateTime     @default(now())
  repositories Repository[]
}

/// A repository imported from GitHub. The user picks which ones EngineerDNA
/// may analyze later via `selectedForAnalysis`.
model Repository {
  id                  String        @id @default(uuid()) @db.Uuid
  githubAccountId     String        @db.Uuid
  account             GithubAccount @relation(fields: [githubAccountId], references: [id], onDelete: Cascade)
  githubId            String
  name                String
  fullName            String
  description         String?
  language            String?
  stars               Int           @default(0)
  forks               Int           @default(0)
  isPrivate           Boolean       @default(false)
  htmlUrl             String
  defaultBranch       String?
  pushedAt            DateTime?
  selectedForAnalysis Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  analysis RepositoryAnalysis?

  @@unique([githubAccountId, githubId])
  @@index([githubAccountId])
}

/// An engineering report for a repository, produced asynchronously by the LLM
/// from the repository's facts. One per repository (re-running replaces it).
model RepositoryAnalysis {
  id           String         @id @default(uuid()) @db.Uuid
  repositoryId String         @unique @db.Uuid
  repository   Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  status       AnalysisStatus @default(PENDING)
  report       Json?
  model        String?
  error        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

/// The Engineering Passport — a developer's verified identity. One per user.
/// Rich content sections are stored as JSON; skills are relational because
/// they carry the verification lifecycle that later modules act on.
model Profile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @db.Uuid
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline           String?
  about              String?
  location           String?
  websiteUrl         String?
  githubUsername     String?
  leetcodeUsername   String?
  codeforcesUsername String?
  openToWork         Boolean  @default(false)
  isPublic           Boolean  @default(false)
  education          Json     @default("[]")
  experience         Json     @default("[]")
  projects           Json     @default("[]")
  achievements       Json     @default("[]")
  certifications     Json     @default("[]")
  socialLinks        Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  skills Skill[]
}

/// A skill on a passport. Self-added skills are CLAIMED until evidence verifies
/// them in a later module.
model Skill {
  id        String      @id @default(uuid()) @db.Uuid
  profileId String      @db.Uuid
  profile   Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  category  String?
  status    SkillStatus @default(CLAIMED)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([profileId, name])
  @@index([profileId])
}

/// Opaque refresh tokens, stored hashed. One row per issued token so we can
/// rotate (delete-on-use) and revoke individual sessions.
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
