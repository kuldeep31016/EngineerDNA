// EngineerDNA — Prisma schema (Module 2: Authentication & User Management).
// PostgreSQL is the canonical relational store. Neo4j (added later) is a
// projection. Only auth/user tables exist at this stage — feature tables are
// added by their owning modules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum AuthProvider {
  GITHUB
  GOOGLE
  CREDENTIALS
}

/// Verification lifecycle for a skill. Self-added skills start CLAIMED; later
/// modules move them to VERIFIED (with evidence) or REFUTED.
enum SkillStatus {
  CLAIMED
  VERIFYING
  VERIFIED
  REFUTED
}

/// Lifecycle of a repository analysis job (Module 5).
enum AnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/// Category of a technology in the evidence store (Module 6).
enum TechCategory {
  LANGUAGE
  FRAMEWORK
  DATABASE
  CLOUD
  TESTING
  DEPLOYMENT
  LIBRARY
  TOOL
  AUTH
}

/// USED = proven by real implementation; MENTIONED = declared but unconfirmed.
enum EvidenceStrength {
  MENTIONED
  USED
}

/// Lifecycle of an AI interview session (Module 11). Questions are GENERATED
/// first, then EVALUATED once the candidate submits answers.
enum InterviewStatus {
  GENERATED
  EVALUATED
}

/// Job posting classification (recruiter Job Posts).
enum JobType {
  FULL_TIME
  INTERNSHIP
  CONTRACT
  PART_TIME
}

enum JobWorkMode {
  ONSITE
  REMOTE
  HYBRID
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  INTERVIEW
  REJECTED
  SELECTED
}

/// A recruiter→student conversation. Starts PENDING (an invitation); the student
/// must ACCEPT before either side can chat — this prevents recruiter spam.
enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

/// Where a piece of evidence came from. Source-typed so non-repo signals
/// (interviews, learning, open source) can be first-class evidence later.
enum EvidenceSource {
  GITHUB_REPO
  INTERVIEW
  LEARNING
  OPEN_SOURCE
  RESUME
}

/// A platform user. Created automatically on first OAuth login.
model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  name         String?
  profileImage String?
  role         Role         @default(STUDENT)
  provider     AuthProvider
  providerId   String
  // Set only for CREDENTIALS (recruiter) accounts; OAuth users have none.
  passwordHash String?
  // Email verification is structure-only for now (OAuth emails are trusted).
  isVerified   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lastLogin    DateTime?

  refreshTokens RefreshToken[]
  profile       Profile?
  githubAccount GithubAccount?
  evidence      TechEvidence[]
  interviews    Interview[]
  resumeReview  ResumeReview?
  roadmap       LearningRoadmap?
  ossRecommendation OssRecommendation?
  portfolio     Portfolio?
  shortlists    Shortlist[]     @relation("RecruiterShortlists")
  shortlistedBy Shortlist[]     @relation("CandidateShortlistedBy")
  recruiterProfile RecruiterProfile?
  jobs          JobPost[]       @relation("RecruiterJobs")
  subscription  RecruiterSubscription?
  payments      Payment[]
  applications  JobApplication[] @relation("StudentApplications")
  notifications Notification[]
  company       Company?
  recruiterConversations Conversation[] @relation("RecruiterConversations")
  studentConversations   Conversation[] @relation("StudentConversations")
  sentMessages           Message[]      @relation("SentMessages")

  // A provider account maps to exactly one user.
  @@unique([provider, providerId])
  @@index([email])
}

/// A connected GitHub account (separate from login). Holds the OAuth access
/// token (stored ENCRYPTED at rest) used to import repositories.
model GithubAccount {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @unique @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubUserId String
  githubLogin  String
  accessToken  String // encrypted (AES-256-GCM)
  scope        String?
  connectedAt  DateTime     @default(now())
  repositories Repository[]
}

/// A repository imported from GitHub. The user picks which ones EngineerDNA
/// may analyze later via `selectedForAnalysis`.
model Repository {
  id                  String        @id @default(uuid()) @db.Uuid
  githubAccountId     String        @db.Uuid
  account             GithubAccount @relation(fields: [githubAccountId], references: [id], onDelete: Cascade)
  githubId            String
  name                String
  fullName            String
  description         String?
  language            String?
  stars               Int           @default(0)
  forks               Int           @default(0)
  isPrivate           Boolean       @default(false)
  // True when this repo is a fork. Forks the user never committed to must not
  // count as evidence (trust: don't pass off someone else's project as yours).
  isFork              Boolean       @default(false)
  // Commits authored by the connected GitHub account (captured at evidence
  // build). 0 → the repo is excluded from evidence.
  ownCommits          Int           @default(0)
  htmlUrl             String
  defaultBranch       String?
  pushedAt            DateTime?
  // GitHub repo creation date — proxy for "when the developer started using a
  // technology" in the Evidence Timeline.
  repoCreatedAt       DateTime?
  selectedForAnalysis Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  analysis RepositoryAnalysis?
  evidence TechEvidence[]

  @@unique([githubAccountId, githubId])
  @@index([githubAccountId])
}

/// Evidence that a developer USED or MENTIONED a technology in a repository.
/// This is the reusable "truth layer": skill verification, DNA, and ranking
/// all read from here rather than re-scanning repositories.
model TechEvidence {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositoryId String           @db.Uuid
  repository   Repository       @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  technology   String
  category     TechCategory
  strength     EvidenceStrength
  confidence   Float            @default(0.5)
  source       EvidenceSource   @default(GITHUB_REPO)
  proofs       Json             @default("[]")
  firstSeenAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([repositoryId, technology])
  @@index([userId, technology])
  @@index([userId, category])
}

/// An engineering report for a repository, produced asynchronously by the LLM
/// from the repository's facts. One per repository (re-running replaces it).
model RepositoryAnalysis {
  id           String         @id @default(uuid()) @db.Uuid
  repositoryId String         @unique @db.Uuid
  repository   Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  status       AnalysisStatus @default(PENDING)
  report       Json?
  model        String?
  error        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

/// An AI interview session (Module 11). Questions are generated from the
/// developer's verified evidence; answers and the grading report are stored so
/// history and improvement over time are visible. JSON columns hold the
/// question/answer/report shapes defined in the shared contract.
model Interview {
  id           String          @id @default(uuid()) @db.Uuid
  userId       String          @db.Uuid
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       InterviewStatus @default(GENERATED)
  role         String?
  candidateName String?
  resumeText   String?
  topics       Json            @default("[]")
  questions    Json            @default("[]")
  answers      Json            @default("[]")
  report       Json?
  // Anti-cheat / integrity signals captured in the browser (fullscreen exits,
  // tab switches, focus loss, whether the session was auto-terminated).
  proctoring   Json?
  overallScore Int?
  model        String?
  createdAt    DateTime        @default(now())
  evaluatedAt  DateTime?

  @@index([userId])
}

/// A job posting created by a recruiter. Required skills are matched against
/// verified candidate evidence to surface qualified engineers.
model JobPost {
  id               String      @id @default(uuid()) @db.Uuid
  recruiterId      String      @db.Uuid
  recruiter        User        @relation("RecruiterJobs", fields: [recruiterId], references: [id], onDelete: Cascade)
  companyId        String?     @db.Uuid
  company          Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  title            String
  description      String
  responsibilities String?
  requirements     String?
  benefits         String?
  skills           Json        @default("[]")
  location         String?
  type             JobType     @default(FULL_TIME)
  workMode         JobWorkMode @default(ONSITE)
  status           JobStatus   @default(OPEN)
  salaryMin        Int?
  salaryMax        Int?
  experience       String?
  deadline         DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  applications     JobApplication[]

  @@index([recruiterId])
  @@index([companyId])
  @@index([status])
}

/// A recruiter's paid subscription. One per user. Access to recruiter features
/// requires an active (non-expired) subscription. Created only after a verified
/// Razorpay payment.
model RecruiterSubscription {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              String
  status            String    @default("inactive")
  jobPostLimit      Int       @default(0)
  jobPostsUsed      Int       @default(0)
  amount            Int       @default(0)
  currency          String    @default("INR")
  razorpayOrderId   String?
  razorpayPaymentId String?
  startedAt         DateTime?
  createdAt         DateTime  @default(now())
  expiresAt         DateTime?
  updatedAt         DateTime  @updatedAt

  payments          Payment[]
}

/// A payment record. Created when an order is placed; marked paid only after the
/// Razorpay signature is verified on the backend.
model Payment {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?  @db.Uuid
  subscription   RecruiterSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  orderId        String
  paymentId      String?
  signature      String?
  amount         Int
  currency       String   @default("INR")
  status         String   @default("created")
  invoiceNumber  String?  @unique
  provider       String   @default("razorpay")
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([orderId])
}

/// Company details for a recruiter account (Module 14 — role-based access).
model RecruiterProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String
  companyWebsite String?
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// A recruiter's shortlist entry for a candidate (Module 14).
model Shortlist {
  id          String   @id @default(uuid()) @db.Uuid
  recruiterId String   @db.Uuid
  recruiter   User     @relation("RecruiterShortlists", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidateId String   @db.Uuid
  candidate   User     @relation("CandidateShortlistedBy", fields: [candidateId], references: [id], onDelete: Cascade)
  note        String?
  createdAt   DateTime @default(now())

  @@unique([recruiterId, candidateId])
  @@index([recruiterId])
}

/// The latest AI resume review for a user (Module 12). One per user — a new
/// review replaces the old one. The structured report is stored as JSON.
model ResumeReview {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeText       String
  inputHash        String?
  atsScore         Int
  engineeringScore Int
  report           Json
  model            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// A generated portfolio (Module 18). One per user. The extracted JSON (data)
/// is the single source the themed components render; the LLM fills it once from
/// the resume (sourceHash caches that), then the user edits are stored here.
model Portfolio {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data       Json
  theme      String   @default("modern")
  published  Boolean  @default(false)
  slug       String?  @unique
  sourceHash String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Cached open-source recommendations for a user (Module 17). Rebuilt when the
/// skill-set changes or the cache goes stale — keeps GitHub API calls down.
model OssRecommendation {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillsHash String
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// A personalized learning roadmap for a target role (Module 13). One per user.
/// The LLM-generated stages (skills, why, projects, resources) are stored; each
/// node's status/progress is recomputed live from current evidence on read.
model LearningRoadmap {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  summary   String
  stages    Json
  model     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// The Engineering Passport — a developer's verified identity. One per user.
/// Rich content sections are stored as JSON; skills are relational because
/// they carry the verification lifecycle that later modules act on.
model Profile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @db.Uuid
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Handle for the public verified profile at /u/<username>.
  username           String?  @unique
  headline           String?
  about              String?
  location           String?
  websiteUrl         String?
  githubUsername     String?
  leetcodeUsername   String?
  codeforcesUsername String?
  openToWork         Boolean  @default(false)
  isPublic           Boolean  @default(false)
  // Recruiter-facing hiring signals the student fills in.
  college            String?
  experienceYears    Int?
  availability       String?
  expectedSalary     String?
  education          Json     @default("[]")
  experience         Json     @default("[]")
  projects           Json     @default("[]")
  achievements       Json     @default("[]")
  certifications     Json     @default("[]")
  socialLinks        Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  skills Skill[]
}

/// A skill on a passport. Self-added skills are CLAIMED until evidence verifies
/// them in a later module.
model Skill {
  id        String      @id @default(uuid()) @db.Uuid
  profileId String      @db.Uuid
  profile   Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  category   String?
  status     SkillStatus @default(CLAIMED)
  // Set by the Skill Verification Engine (Module 7).
  confidence Float       @default(0)
  verifiedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([profileId, name])
  @@index([profileId])
}

/// Opaque refresh tokens, stored hashed. One row per issued token so we can
/// rotate (delete-on-use) and revoke individual sessions.
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

/// A recruiter's company profile. Auto-created from RecruiterProfile on first
/// job post. One company per recruiter for now — expandable to multi-company later.
model Company {
  id          String    @id @default(uuid()) @db.Uuid
  recruiterId String    @unique @db.Uuid
  recruiter   User      @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  name        String
  logo        String?
  website     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jobs        JobPost[]
}

/// A student's job application. One application per job per student.
model JobApplication {
  id          String            @id @default(uuid()) @db.Uuid
  jobId       String            @db.Uuid
  job         JobPost           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  studentId   String            @db.Uuid
  student     User              @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)
  // The resume submitted WITH this application (extracted client-side). Kept on
  // the application itself — distinct from any saved passport/portfolio resume.
  resumeText  String?
  coverLetter String?
  status      ApplicationStatus @default(APPLIED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, studentId])
  @@index([studentId])
  @@index([jobId])
}

/// In-app notification for a user. Created when application status changes.
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

/// A recruiter→student conversation. One per (recruiter, student) pair. The
/// recruiter opens it with an invitation (status PENDING); messaging is only
/// allowed once the student ACCEPTs — keeps recruiters from spamming everyone.
model Conversation {
  id          String             @id @default(uuid()) @db.Uuid
  recruiterId String             @db.Uuid
  recruiter   User               @relation("RecruiterConversations", fields: [recruiterId], references: [id], onDelete: Cascade)
  studentId   String             @db.Uuid
  student     User               @relation("StudentConversations", fields: [studentId], references: [id], onDelete: Cascade)
  status      ConversationStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  messages Message[]

  @@unique([recruiterId, studentId])
  @@index([studentId])
  @@index([recruiterId])
}

/// A single chat message. `attachmentUrl` carries shared links (meeting link,
/// interview link, offer letter PDF, etc.) — labelled by `attachmentLabel`.
model Message {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @db.Uuid
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String       @db.Uuid
  sender          User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body            String
  attachmentUrl   String?
  attachmentLabel String?
  readAt          DateTime?
  createdAt       DateTime     @default(now())

  @@index([conversationId])
}
