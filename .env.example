# ============================================================================
# EngineerDNA — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every value the apps need is declared here — no hardcoded config anywhere.
# ============================================================================

# ---- Core ports ----
WEB_PORT=3000
API_PORT=4000
# Origin the API trusts for CORS (the web app).
WEB_ORIGIN=http://localhost:3000
# URL the web app uses to reach the API (browser-facing).
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Public base URL of the API itself — used to build OAuth callback URLs.
API_PUBLIC_URL=http://localhost:4000/api

# ---- PostgreSQL (canonical relational store) ----
POSTGRES_USER=engineerdna
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=engineerdna
# Inside docker-compose the host is `postgres`; locally it is `localhost`.
DATABASE_URL=postgresql://engineerdna:change_me_postgres@localhost:5432/engineerdna?schema=public

# ---- Redis (cache + job queue) ----
REDIS_URL=redis://localhost:6379

# ---- Neo4j (knowledge / DNA graph — projection of Postgres) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j

# ---- Auth ----
JWT_SECRET=change_me_to_a_long_random_string
# Used to encrypt stored GitHub access tokens at rest (64 hex chars).
# If left blank, a key is derived from JWT_SECRET (fine for local dev).
ENCRYPTION_KEY=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- LLM providers (AI work happens in the API/worker, never the browser) ----
ANTHROPIC_API_KEY=
# Optional: override the Claude model used for analysis (defaults to claude-opus-4-8).
ANTHROPIC_MODEL=
OPENAI_API_KEY=

# ---- Object storage (future: resumes, generated portfolios) ----
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Razorpay (Test Mode) — recruiter subscriptions. Get from dashboard.razorpay.com (Test).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Transactional email (SMTP, free) — application confirmation + status emails ----
# Works with any SMTP provider: Gmail (app password), Zoho, Brevo, Mailtrap, etc.
# If left blank, emails are logged instead of sent (the app still works fully).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# From address shown to recipients (optional).
SMTP_FROM=EngineerDNA <no-reply@engineerdna.app>
# Base URL of the web app, used for links inside emails.
WEB_URL=http://localhost:3000
