{
  "name": "engineerdna",
  "version": "0.1.0",
  "private": true,
  "description": "EngineerDNA — Evidence Over Claims. Verified engineering identity platform.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "docker compose up -d postgres && turbo run dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema apps/api/prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
